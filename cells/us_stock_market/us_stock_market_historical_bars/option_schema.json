{
    "input_schema": {
        "required": [
            "symbols",
            "timeframe",
            "start",
            "end"
        ],
        "properties": {
            "symbols": {
                "type": "string",
                "description": "Comma-separated list of symbols (e.g. NVDA,AMD)"
            },
            "timeframe": {
                "type": "string",
                "description": "Timeframe resolution (e.g., 1Min, 5Min, 15Min, 1Hour, 1Day, 1Week, 1Month)"
            },
            "start": {
                "type": "string",
                "description": "Start timestamp in RFC-3339 format (e.g., 2024-01-01T00:00:00Z)"
            },
            "end": {
                "type": "string",
                "description": "End timestamp in RFC-3339 format (e.g., 2024-01-10T00:00:00Z)"
            },
            "limit": {
                "type": "integer",
                "description": "Maximum number of data points to return",
                "default": 1000
            },
            "feed": {
                "type": "string",
                "description": "Data feed (iex, sip)",
                "enum": [
                    "iex",
                    "sip"
                ],
                "default": "iex"
            },
            "adjustment": {
                "type": "string",
                "description": "Corporate action adjustment (raw, split, dividend, all)",
                "enum": [
                    "raw",
                    "split",
                    "dividend",
                    "all"
                ],
                "default": "all"
            },
            "include_raw": {
                "type": "boolean",
                "default": false
            }
        }
    },
    "runtime_contract": {
        "reads_file": true,
        "issues_token": false,
        "makes_network_call": true,
        "transport": "REST"
    },
    "outbox_contract": {
        "top_level_keys": [
            "message",
            "status",
            "lim_aplc"
        ],
        "data_shape": [
            "normalized",
            "raw",
            "request_meta",
            "US Stock_status"
        ]
    },
    "source_files": {
        "worker": "kernel_parts/worker.py",
        "http_client": "kernel_parts/http_client.py",
        "bridge": "bridge.py",
        "selftest": "selftest.py"
    }
}

