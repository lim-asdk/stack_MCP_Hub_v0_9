{
    "input_schema": {
        "required": [
            "symbol"
        ],
        "properties": {
            "symbol": {
                "type": "string",
                "description": "Stock ticker symbol (e.g. AAPL)"
            }
        }
    },
    "runtime_contract": {
        "reads_file": true,
        "issues_token": false,
        "makes_network_call": true,
        "transport": "REST"
    },
    "outbox_contract": {
        "top_level_keys": [
            "message",
            "status",
            "lim_aplc"
        ],
        "data_shape": [
            "metrics"
        ]
    },
    "source_files": {
        "worker": "kernel_parts/worker.py",
        "bridge": "bridge.py",
        "selftest": "selftest.py"
    }
}

